pipeline {
    agent {
        kubernetes {
            yaml """
apiVersion: v1
kind: Pod
metadata:
  labels:
    app: jenkins-agent
spec:
  serviceAccountName: jenkins
  containers:
  - name: jnlp
    image: docker.m.daocloud.io/jenkins/inbound-agent:alpine
    securityContext:
      runAsUser: 0
  - name: dind
    image: docker.m.daocloud.io/library/docker:dind
    imagePullPolicy: IfNotPresent
    securityContext:
      privileged: true
    env:
    - name: DOCKER_TLS_CERTDIR
      value: ""
    tty: true
  - name: nginx 
    image: docker.m.daocloud.io/library/nginx:alpine
    imagePullPolicy: IfNotPresent
    command: ['cat']
    tty: true
  - name: docker
    image: docker.m.daocloud.io/library/docker:latest
    imagePullPolicy: IfNotPresent
    command: ['cat']
    tty: true
    env:
    - name: DOCKER_HOST
      value: tcp://localhost:2375
  - name: trivy
    image: docker.m.daocloud.io/aquasec/trivy:0.43.0
    imagePullPolicy: IfNotPresent
    command: ['cat']
    tty: true
  - name: kubectl
    image: bitnami/kubectl:latest
    securityContext:
      runAsUser: 0
    command: ['cat']
    tty: true
"""
        }
    }

    environment {
        REGISTRY_DOMAIN = "crpi-v1qihtqp9ipem36a.cn-shanghai.personal.cr.aliyuncs.com"
        REGISTRY_REPO = "crpi-v1qihtqp9ipem36a.cn-shanghai.personal.cr.aliyuncs.com/imbucket/bucket"
        IMAGE_NAME = "demo-app"
        VERSION = "v1.0.${BUILD_NUMBER}"
    }

    stages {
        stage('Checkout') {
            steps {
                git branch: 'main', credentialsId: 'github-creds', url: 'https://github.com/jasonsproject/Demo.git'
            }
        }
        stage('Build Image') {
            steps {
                container('docker') {
                    // Diagnostic logs to check workspace structure
                    sh 'pwd'
                    sh 'ls -R'
                    // Wait for DinD to be ready
                    sh 'while ! docker info > /dev/null 2>&1; do echo "waiting for dind..."; sleep 2; done'
                    // Using direct relative path context
                    sh 'docker build -t $IMAGE_NAME:$VERSION ./app'
                    sh 'docker tag $IMAGE_NAME:$VERSION $IMAGE_NAME:latest'
                }
            }
        }
        stage('Push Image') {
            steps {
                container('docker') {
                    withCredentials([usernamePassword(
                        credentialsId: 'aliyun-registry-creds',
                        usernameVariable: 'REGISTRY_USER',
                        passwordVariable: 'REGISTRY_PASS'
                    )]) {
                        sh 'echo $REGISTRY_PASS | docker login -u $REGISTRY_USER --password-stdin $REGISTRY_DOMAIN'
                        sh 'docker tag $IMAGE_NAME:$VERSION $REGISTRY_REPO:$VERSION'
                        sh 'docker push $REGISTRY_REPO:$VERSION'
                    }
                }
            }
        }

        stage('Deploy to Green') {
            steps {
                container('kubectl') {
                    // Update image to the newly built one
                    sh 'sed -i "s|image: .*|image: $REGISTRY_REPO:$VERSION|g" $WORKSPACE/k8s/green-deployment.yaml'
                    sh 'kubectl apply -f $WORKSPACE/k8s/green-deployment.yaml'
                    echo "Green environment deployed."
                }
            }
        }

        stage('Manual Approval') {
            steps {
                input message: "Promote Green to Blue (Live)?", ok: "Promote"
            }
        }

        stage('Switch Traffic') {
            steps {
                container('kubectl') {
                    // Switch service to point to green
                    sh """kubectl patch service demo-service -p '{"spec":{"selector":{"version":"green"}}}'"""
                    echo "Traffic switched to Green environment!"
                }
            }
        }
    }
}